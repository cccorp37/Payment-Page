{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A payment transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "method": { "type": "string" },
        "account": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "transactionId": { "type": "string" },
        "note": { "type": "string" },
        "error": { "type": "string" }
      },
      "required": ["amount", "method", "date", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Admin settings for the app",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "email": { "type": "string" }
      }
    }
  },
  "firestore": {
    "transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores all payment transactions"
    },
    "settings/admin": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores admin settings"
    }
  }
}
